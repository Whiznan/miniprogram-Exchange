<t-navbar title="发布动态">
  <image slot="left" src="/static/iconfont/返回.svg" style="width:48rpx;height:48rpx;padding:0 16rpx" bindtap="goBack" />
</t-navbar>
<view class="page">
  <view class="release-container">
    <view class="upload box">
      <t-upload t-class="upload-class" media-type="{{['image']}}" files="{{originFiles}}" gridConfig="{{gridConfig}}" bind:success="handleSuccess" bind:remove="handleRemove" max="4" />
    </view>
    <view class="desc box">
      <view class="desc-label">添加标题</view>
      <t-textarea t-class="desc-class" t-class-textarea="placeholder-class" placeholder="一句话描述你要发布的内容" maxlength="500" disableDefaultPadding="{{true}}" indicator />
    </view>
    <view class="taggroup box">
      <t-cell t-class-title="cell-title-class" t-class-note="cell-note-class" title="添加标签">
        <block wx:for="{{tags}}" wx:key="index">
          <t-check-tag t-class="tag-class" size="medium" checked="{{index === activeTagIndex}}" variant="dark" content="#{{item}}" slot="note" data-index="{{index}}" bindtap="onTagChange" />
        </block>
      </t-cell>
    </view>
    <view class="location box">
      <t-cell title="所在位置" hover bindtap="gotoMap">
        <image slot="left-icon" src="/static/iconfont/位置.svg" style="width:32rpx;height:32rpx" />
        <image slot="right-icon" src="/static/iconfont/向右.svg" style="width:32rpx;height:32rpx" />
      </t-cell>
    </view>
    <view class="btngroup box">
      <t-button t-class="btn-class" theme="light" size="large" bindtap="saveDraft">
        <image src="/static/iconfont/草稿箱.svg" style="width:28rpx;height:28rpx;vertical-align:middle;margin-right:8rpx" />
        存草稿
      </t-button>
      <t-button t-class="btn-class" theme="primary" size="large" bindtap="release">
        <image src="/static/iconfont/发布.svg" style="width:28rpx;height:28rpx;vertical-align:middle;margin-right:8rpx" />
        发布
      </t-button>
    </view>
  </view>
</view>